{
  "name": "mark-cv",
  "version": "2.0.0-beta.2",
  "description": "Markdown-first resume renderer with themeable HTML and A4 PDF output.",
  "type": "module",
  "repository": "https://github.com/BigLiao/markCV/",
  "homepage": "https://github.com/BigLiao/markCV/",
  "license": "MIT",
  "author": "bigLiao",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "markdown",
    "resume",
    "cv",
    "pdf",
    "theme"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "markcv": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli/index.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "cheerio": "1.0.0",
    "chokidar": "^4.0.3",
    "fs-extra": "^11.3.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "open": "^10.2.0",
    "playwright": "^1.54.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
